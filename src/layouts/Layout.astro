---
import '../styles/global.css';
import 'lenis/dist/lenis.css';

interface Props {
  title: string;
  description?: string;
  legal?: boolean;
  bodyClass?: string;
}

const {
  title,
  description = 'Ediz Yılmaz — Computer Engineering student & iOS indie developer.',
  legal = false,
  bodyClass = '',
} = Astro.props;

const classes = [legal ? 'legal' : '', bodyClass].filter(Boolean).join(' ');
const defaultSpotifyStatusEndpoint = 'https://edizy-spotify-status.kickle-edizy.workers.dev';
const spotifyStatusEndpoint = import.meta.env.PUBLIC_SPOTIFY_STATUS_ENDPOINT?.trim() || defaultSpotifyStatusEndpoint;

const logoDots = [
  [6.6,72.7],[6.6,59.5],[6.6,46.3],[19.8,85.9],[19.8,72.7],[19.8,59.5],[19.8,46.3],[19.8,33],
  [33,85.9],[33,59.5],[33,33],[46.3,85.9],[46.3,59.5],[46.3,33],[59.5,85.9],[59.5,59.5],
  [59.5,46.3],[85.8,72.7],[85.8,59.5],[85.8,46.3],[99.1,85.9],[99.1,72.7],[99.1,33],
  [112.3,85.9],[112.3,33],[125.5,72.7],[125.5,59.5],[125.5,46.3],[125.5,33],[125.5,19.8],
  [138.7,85.9],[138.7,72.7],[138.7,59.5],[138.7,46.3],[138.7,33],[138.7,19.8],[165.1,85.9],
  [165.1,72.7],[165.1,59.5],[165.1,46.3],[165.1,33],[165.1,6.6],[178.3,85.9],[178.3,72.7],
  [178.3,59.5],[178.3,46.3],[178.3,33],[178.3,6.6],[204.7,85.9],[204.7,72.7],[204.7,33],
  [217.9,85.9],[217.9,72.7],[217.9,59.5],[217.9,33],[231.1,85.9],[231.1,59.5],[231.1,46.3],
  [231.1,33],[244.4,85.9],[244.4,46.3],[244.4,33],[257.6,85.9],[257.6,33],[284,99.1],
  [284,59.5],[284,46.3],[284,33],[297.2,99.1],[297.2,72.7],[297.2,59.5],[297.2,46.3],
  [297.2,33],[310.4,99.1],[310.4,85.9],[310.4,72.7],[310.4,59.5],[323.6,85.9],[336.8,72.7],
  [336.8,59.5],[336.8,46.3],[336.8,33],[363.2,85.9],[363.2,72.7],[363.2,59.5],[363.2,46.3],
  [363.2,33],[363.2,6.6],[376.4,85.9],[376.4,72.7],[376.4,59.5],[376.4,46.3],[376.4,33],
  [376.4,6.6],[402.8,85.9],[402.8,72.7],[402.8,59.5],[402.8,46.3],[402.8,33],[402.8,19.8],
  [416,85.9],[416,72.7],[416,59.5],[416,46.3],[416,33],[416,19.8],[442.4,85.9],[442.4,72.7],
  [442.4,59.5],[442.4,46.3],[442.4,33],[455.7,85.9],[455.7,72.7],[455.7,59.5],[455.7,46.3],
  [468.9,33],[482.1,46.3],[482.1,33],[495.3,85.9],[495.3,72.7],[495.3,59.5],[495.3,46.3],
  [508.5,33],[521.7,46.3],[521.7,33],[534.9,85.9],[534.9,72.7],[534.9,59.5],[534.9,46.3],
  [561.4,72.7],[574.6,85.9],[574.6,59.5],[574.6,33],[587.9,85.9],[587.9,59.5],[587.9,33],
  [601.1,72.7],[601.1,59.5],[601.1,46.3],[601.1,33],[614.3,85.9],[614.3,72.7],[614.3,59.5],
  [614.3,46.3],[640.7,85.9],[640.7,72.7],[640.7,33],[653.9,85.9],[653.9,72.7],[653.9,59.5],
  [653.9,33],[667.1,85.9],[667.1,59.5],[667.1,46.3],[667.1,33],[680.3,85.9],[680.3,46.3],
  [680.3,33],[693.5,85.9],[693.5,33],
];

const logoDotColors = ['#ff0000', '#0000ff', '#00ff3c'];
const seeded = (value: number) => {
  const x = Math.sin(value * 9301 + 49297) * 233280;
  return x - Math.floor(x);
};
const logoDotRanks = logoDots
  .map(([x, y], index) => ({ index, score: seeded(x * 19 + y * 31) }))
  .sort((a, b) => a.score - b.score);
const logoDotDelayByIndex = new Map(
  logoDotRanks.map((dot, rank) => [
    dot.index,
    Math.round((rank / Math.max(1, logoDotRanks.length - 1)) * 760),
  ]),
);
const logoDotLitByIndex = new Map(
  logoDotRanks.map((dot, rank) => [
    dot.index,
    rank < Math.round(logoDotRanks.length * 0.38),
  ]),
);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e0c0a" />
    <link rel="icon" type="image/svg+xml" href="/favicon-e-red.svg" />
    <link rel="shortcut icon" type="image/svg+xml" href="/favicon-e-red.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Anton&family=Bitcount+Prop+Double:wght@400;500;600;700&family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..900,0..100,0..1;1,9..144,300..900,0..100,0..1&family=Schibsted+Grotesk:ital,wght@0,400..900;1,400..900&family=JetBrains+Mono:wght@400;500;700&display=swap" />
    <script is:inline>
      try {
        const theme = JSON.parse(sessionStorage.getItem('opening-theme-values') || 'null');
        if (theme) {
          const root = document.documentElement;
          root.style.setProperty('--opening-bg', theme.bg);
          root.style.setProperty('--opening-ink', theme.ink);
          root.style.setProperty('--opening-accent', theme.accent);
          root.style.setProperty('--opening-accent-ink', theme.accentInk || theme.ink);
          root.style.setProperty('--opening-content', theme.content || theme.bg);
          root.style.setProperty('--opening-content-ink', theme.contentInk || theme.ink);
          root.style.setProperty('--opening-soft', theme.soft);
          root.dataset.openingTheme = theme.name;
        }
      } catch (_) {
        // Defaults remain available when storage is unavailable or malformed.
      }
    </script>
    <title>{title}</title>
  </head>
  <body class={classes}>
    <div class="grain" aria-hidden="true"></div>

    <header class="site">
      <div>
        <a href="/" class="logo">
          <span class="dot-logo" aria-hidden="true">
            {logoDots.map(([x, y], index) => (
              <span
                data-lit={logoDotLitByIndex.get(index) ? 'true' : 'false'}
                style={`--x:${(x / 701 * 100).toFixed(3)}%;--y:${(y / 106 * 100).toFixed(3)}%;--dot-color:${logoDotColors[index % logoDotColors.length]};--dot-delay:${logoDotDelayByIndex.get(index) ?? 0}ms`}
              />
            ))}
          </span>
          <span class="sr-only">edizyilmaz</span>
        </a>
        <button
          class="menu-toggle"
          type="button"
          aria-controls="site-menu"
          aria-expanded="false"
        >
          Menu
        </button>
      </div>
    </header>

    <dialog class="site-menu" id="site-menu" aria-labelledby="site-menu-title" tabindex="-1">
      <div class="site-menu__shell">
        <a class="site-menu__brand" href="/">ediz yilmaz</a>
        <h2 id="site-menu-title" class="sr-only">Site menu</h2>
        <button class="site-menu__close" type="button">Close</button>

        <nav class="site-menu__nav" aria-label="Site">
          <section class="site-menu__group site-menu__group--apps">
            <p>Apps</p>
            <a href="/tabu-ekstra/">Tabum Ekstra <span class="site-menu__count">01</span></a>
            <a href="/imposter/">Imposter <span class="site-menu__count">02</span></a>
            <a href="/holy-shift/">Holy Shift <span class="site-menu__count">03</span></a>
          </section>

          <section class="site-menu__group site-menu__group--other" data-open="false">
            <button
              class="site-menu__other-trigger"
              type="button"
              aria-expanded="false"
              aria-controls="site-menu-other-panel"
            >Other</button>
            <div class="site-menu__other-panel" id="site-menu-other-panel">
              <div>
                <a href="https://edyx0.itch.io/ayasofya-kutsal-bilgelik-tasi">Ayasofya</a>
              </div>
            </div>
          </section>

          <a class="site-menu__page-link site-menu__page-link--about" href="/#about">About</a>
        </nav>

        <a
          class="site-menu__music"
          href="https://open.spotify.com/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Open Music on Spotify"
          data-spotify-endpoint={spotifyStatusEndpoint}
        >
          <span class="site-menu__music-label">Music</span>
          <span class="site-menu__music-record" aria-hidden="true">
            <span class="site-menu__music-disc">
              <span class="site-menu__music-cover">
                <img data-spotify-cover alt="" loading="lazy" decoding="async" />
              </span>
            </span>
          </span>
          <span class="site-menu__music-meta" aria-hidden="true">
            <span class="site-menu__music-played" data-spotify-played hidden></span>
            <span class="site-menu__music-title" data-spotify-title>Music</span>
            <span class="site-menu__music-artist" data-spotify-artist>Artist</span>
            <span class="site-menu__music-album" data-spotify-album>Album</span>
          </span>
        </a>

        <div class="site-menu__footer">
          <a href="https://linkedin.com/in/edizylm/">LinkedIn</a>
          <a href="https://github.com/Edyx0">GitHub</a>
          <span>© {new Date().getFullYear()}</span>
        </div>
      </div>
    </dialog>

    <main>
      <slot />
    </main>

    <script>
      import Lenis from 'lenis';

      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      let lenis: Lenis | null = null;

      const mountSmoothScroll = () => {
        lenis?.destroy();
        lenis = null;

        if (reducedMotion.matches) {
          document.documentElement.classList.remove('lenis', 'lenis-smooth');
          return;
        }

        lenis = new Lenis({
          autoRaf: true,
          duration: 1.08,
          easing: (time) => Math.min(1, 1.001 - Math.pow(2, -10 * time)),
          smoothWheel: true,
          syncTouch: false,
          wheelMultiplier: 1,
          touchMultiplier: 1,
          anchors: {
            duration: 1.08,
            easing: (time) => Math.min(1, 1.001 - Math.pow(2, -10 * time)),
          },
          prevent: (node) =>
            document.body.classList.contains('opening-locked') ||
            Boolean(node.closest('dialog, [data-smooth-gallery], [data-lenis-prevent]')),
        });

        window.dispatchEvent(new CustomEvent('smooth-scroll-ready', { detail: lenis }));
      };

      mountSmoothScroll();
      reducedMotion.addEventListener('change', mountSmoothScroll);
    </script>

    <script is:inline>
      (() => {
        const colors = ['#ff0000', '#0000ff', '#00ff3c'];
        const seeded = (value) => {
          const x = Math.sin(value * 9301 + 49297) * 233280;
          return x - Math.floor(x);
        };

        const readLabel = (element, fallback = '') => {
          const srOnly = element.querySelector('.sr-only');
          return (
            element.dataset.pixelLabel ||
            srOnly?.textContent ||
            element.textContent ||
            fallback
          ).trim();
        };

        const sampleBitcountDots = (label, mode) => {
          const canvas = document.createElement('canvas');
          const ctx = canvas.getContext('2d', { willReadFrequently: true });
          if (!ctx || !label) return null;

          const fontSize = mode === 'logo' ? 176 : 184;
          const fontWeight = 400;
          const family = '"Bitcount Prop Double", "Bitcount Prop Single", monospace';
          ctx.font = `${fontWeight} ${fontSize}px ${family}`;
          ctx.textBaseline = 'alphabetic';

          const metrics = ctx.measureText(label);
          const left = Math.ceil(Math.abs(metrics.actualBoundingBoxLeft || 0)) + 28;
          const right = Math.ceil(metrics.actualBoundingBoxRight || metrics.width) + 28;
          const ascent = Math.ceil(metrics.actualBoundingBoxAscent || fontSize * 0.76) + 28;
          const descent = Math.ceil(metrics.actualBoundingBoxDescent || fontSize * 0.22) + 28;
          canvas.width = Math.max(20, left + right);
          canvas.height = Math.max(20, ascent + descent);

          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.fillStyle = '#fff';
          ctx.font = `${fontWeight} ${fontSize}px ${family}`;
          ctx.textBaseline = 'alphabetic';
          ctx.fillText(label, left, ascent);

          const image = ctx.getImageData(0, 0, canvas.width, canvas.height).data;
          let inkMinX = Infinity;
          let inkMinY = Infinity;
          let inkMaxX = -Infinity;
          let inkMaxY = -Infinity;

          for (let y = 0; y < canvas.height; y += 1) {
            for (let x = 0; x < canvas.width; x += 1) {
              const alpha = image[(y * canvas.width + x) * 4 + 3];
              if (alpha < 64) continue;
              inkMinX = Math.min(inkMinX, x);
              inkMinY = Math.min(inkMinY, y);
              inkMaxX = Math.max(inkMaxX, x);
              inkMaxY = Math.max(inkMaxY, y);
            }
          }

          if (!Number.isFinite(inkMinX)) return null;

          const pitch = fontSize * 0.075;
          const radius = pitch * 0.32;
          const dots = [];
          const gridMinX = Math.floor(inkMinX / pitch) * pitch;
          const gridMinY = Math.floor(inkMinY / pitch) * pitch;
          const gridMaxX = Math.ceil(inkMaxX / pitch) * pitch;
          const gridMaxY = Math.ceil(inkMaxY / pitch) * pitch;

          for (let gy = 0, y = gridMinY; y <= gridMaxY; gy += 1, y += pitch) {
            for (let gx = 0, x = gridMinX; x <= gridMaxX; gx += 1, x += pitch) {
              let alpha = 0;
              let peak = 0;
              let samples = 0;

              for (let yy = Math.max(0, Math.floor(y - radius)); yy <= Math.min(canvas.height - 1, Math.ceil(y + radius)); yy += 1) {
                for (let xx = Math.max(0, Math.floor(x - radius)); xx <= Math.min(canvas.width - 1, Math.ceil(x + radius)); xx += 1) {
                  const distance = Math.hypot(xx - x, yy - y);
                  if (distance > radius) continue;
                  const a = image[(yy * canvas.width + xx) * 4 + 3];
                  alpha += a;
                  peak = Math.max(peak, a);
                  samples += 1;
                }
              }

              const average = alpha / Math.max(1, samples);
              if (peak < 112 || average < 24) continue;
              dots.push({ x: gx * pitch, y: gy * pitch });
            }
          }

          if (!dots.length) return null;

          const minX = Math.min(...dots.map((dot) => dot.x));
          const minY = Math.min(...dots.map((dot) => dot.y));
          const maxX = Math.max(...dots.map((dot) => dot.x));
          const maxY = Math.max(...dots.map((dot) => dot.y));

          return {
            dots: dots.map((dot) => ({ x: dot.x - minX, y: dot.y - minY })),
            width: Math.max(1, maxX - minX + pitch),
            height: Math.max(1, maxY - minY + pitch),
            dotSize: pitch * 0.46,
          };
        };

        const rankedDots = (dots, salt) =>
          dots
            .map((dot, index) => ({
              ...dot,
              index,
              score: seeded(dot.x * 19 + dot.y * 31 + salt * 7),
            }))
            .sort((a, b) => a.score - b.score);

        const makeDot = ({ x, y, color, delay, lit }) => {
          const dot = document.createElement('span');
          dot.className = 'dot-word__dot';
          dot.dataset.lit = lit ? 'true' : 'false';
          dot.style.setProperty('--dot-x', x);
          dot.style.setProperty('--dot-y', y);
          dot.style.setProperty('--dot-color', color);
          dot.style.setProperty('--dot-delay', `${delay}ms`);
          return dot;
        };

        const clamp = (value, min, max) => Math.min(max, Math.max(min, value));

        const getWordLayout = (element, sampled, mode) => {
          if (mode === 'nav') {
            const scale = clamp(window.innerWidth / 7600, 0.12, 0.18);
            return {
              scale,
              dotSize: clamp(sampled.dotSize * scale * 0.72, 1.05, 1.55),
            };
          }

          const row = element.closest('.brand-row');
          const rowWidth = row?.getBoundingClientRect().width || window.innerWidth * 0.48;
          const available = clamp(rowWidth - 220, 300, 680);
          const scale = clamp(available / Math.max(1, sampled.width), 0.34, 0.56);

          return {
            scale,
            dotSize: clamp(sampled.dotSize * scale * 0.78, 3.05, 4.45),
          };
        };

        const paintDotCanvas = (canvas, sampled, layout, mode, elapsed = 0, active = false) => {
          const dpr = Math.min(2, window.devicePixelRatio || 1);
          const width = Math.ceil(sampled.width * layout.scale + layout.dotSize * 2);
          const height = Math.ceil(sampled.height * layout.scale + layout.dotSize * 2);
          if (canvas.width !== Math.ceil(width * dpr) || canvas.height !== Math.ceil(height * dpr)) {
            canvas.width = Math.ceil(width * dpr);
            canvas.height = Math.ceil(height * dpr);
            canvas.style.width = `${width}px`;
            canvas.style.height = `${height}px`;
          }

          const ctx = canvas.getContext('2d');
          if (!ctx) return;
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          ctx.clearRect(0, 0, width, height);

          sampled.dots.forEach((dot, index) => {
            const rank = dot.rank ?? index;
            const delay = (rank / Math.max(1, sampled.dots.length - 1)) * 760;
            const phase = active ? ((elapsed - delay * 2.2) % 3150 + 3150) % 3150 / 3150 : 0;
            const color = mode === 'nav' ? 'var(--nav-pixel, #00ff3c)' : colors[index % colors.length];
            const x = dot.x * layout.scale + layout.dotSize;
            const y = dot.y * layout.scale + layout.dotSize;
            let radius = layout.dotSize / 2;
            let fill = '#eee7db';
            let alpha = 0.86;
            let glow = 0;

            if (active && phase > 0.08 && phase < 0.46) {
              const intensity = Math.sin(((phase - 0.08) / 0.38) * Math.PI);
              radius *= 1 + intensity * 0.08;
              fill = color.startsWith('var(') ? '#eee7db' : color;
              alpha = 0.72 + intensity * 0.28;
              glow = intensity * 5;
            }

            ctx.globalAlpha = alpha;
            if (glow > 0) {
              ctx.shadowColor = fill;
              ctx.shadowBlur = glow;
            } else {
              ctx.shadowBlur = 0;
            }
            ctx.fillStyle = fill;
            ctx.beginPath();
            ctx.arc(x, y, radius, 0, Math.PI * 2);
            ctx.fill();
          });

          ctx.globalAlpha = 1;
          ctx.shadowBlur = 0;
        };

        const renderWord = (element, label, mode) => {
          const sampled = sampleBitcountDots(label, mode);
          if (!sampled) return;

          const layout = getWordLayout(element, sampled, mode);
          const ranked = rankedDots(sampled.dots, label.length);
          const rankByIndex = new Map(ranked.map((dot, rank) => [dot.index, rank]));
          sampled.dots = sampled.dots.map((dot, index) => ({
            ...dot,
            rank: rankByIndex.get(index) ?? index,
          }));

          const word = document.createElement('span');
          word.className = 'dot-word dot-word--canvas';
          word.setAttribute('aria-hidden', 'true');

          const canvas = document.createElement('canvas');
          canvas.className = 'dot-word__canvas';
          word.append(canvas);

          element.textContent = '';
          element.append(word);

          const srOnly = document.createElement('span');
          srOnly.className = 'sr-only';
          srOnly.textContent = label;
          element.append(srOnly);
          element.dataset.dotWordReady = 'true';
          element.dataset.dotWordSampled = 'true';

          let raf = 0;
          let active = false;
          const target = mode === 'brand' ? element.closest('.brand-row') || element : element;
          const draw = (time = 0) => paintDotCanvas(canvas, sampled, layout, mode, time, active);
          const tick = (time) => {
            draw(time);
            if (active) raf = requestAnimationFrame(tick);
          };
          target.addEventListener('mouseenter', () => {
            active = true;
            cancelAnimationFrame(raf);
            raf = requestAnimationFrame(tick);
          });
          target.addEventListener('mouseleave', () => {
            active = false;
            cancelAnimationFrame(raf);
            draw(0);
          });
          target.addEventListener('focusin', () => {
            active = true;
            cancelAnimationFrame(raf);
            raf = requestAnimationFrame(tick);
          });
          target.addEventListener('focusout', () => {
            active = false;
            cancelAnimationFrame(raf);
            draw(0);
          });
          draw(0);
        };

        const renderLogo = () => {
          const logo = document.querySelector('.dot-logo');
          if (!logo) return;

          const label = logo.closest('.logo')?.querySelector('.sr-only')?.textContent?.trim() || 'edizyilmaz';
          const sampled = sampleBitcountDots(label, 'logo');
          if (!sampled) return;

          const ranked = rankedDots(sampled.dots, label.length);
          const rankByIndex = new Map(ranked.map((dot, rank) => [dot.index, rank]));
          const litCount = Math.round(sampled.dots.length * 0.38);
          logo.textContent = '';
          logo.style.setProperty('--sample-width', String(sampled.width));
          logo.style.setProperty('--sample-height', String(sampled.height));

          sampled.dots.forEach((dot, index) => {
            const rank = rankByIndex.get(index) ?? index;
            const span = document.createElement('span');
            span.dataset.lit = rank < litCount ? 'true' : 'false';
            span.style.setProperty('--x', `${(dot.x / sampled.width) * 100}%`);
            span.style.setProperty('--y', `${(dot.y / sampled.height) * 100}%`);
            span.style.setProperty('--dot-color', colors[index % colors.length]);
            span.style.setProperty('--dot-delay', `${Math.round((rank / Math.max(1, sampled.dots.length - 1)) * 760)}ms`);
            logo.append(span);
          });
        };

        const renderAll = async () => {
          try {
            await document.fonts?.load('400 184px "Bitcount Prop Double"');
            await document.fonts?.ready;
          } catch (_) {
            // The fallback still renders; this only improves fidelity when the web font is ready.
          }

          document.querySelectorAll('header.site nav a').forEach((element) => {
            renderWord(element, readLabel(element), 'nav');
          });
          document.querySelectorAll('.brand-name').forEach((element) => {
            renderWord(element, readLabel(element), 'brand');
          });
        };

        const menu = document.querySelector('#site-menu');
        const menuToggle = document.querySelector('.menu-toggle');
        const menuClose = document.querySelector('.site-menu__close');
        const otherMenu = menu?.querySelector('.site-menu__group--other');
        const otherTrigger = menu?.querySelector('.site-menu__other-trigger');
        const musicLink = menu?.querySelector('.site-menu__music');
        const musicCover = musicLink?.querySelector('[data-spotify-cover]');
        const musicTitle = musicLink?.querySelector('[data-spotify-title]');
        const musicArtist = musicLink?.querySelector('[data-spotify-artist]');
        const musicAlbum = musicLink?.querySelector('[data-spotify-album]');
        const musicPlayed = musicLink?.querySelector('[data-spotify-played]');
        let musicLoaded = false;
        let musicArtworkRequest = 0;

        const setOtherMenuOpen = (open) => {
          otherMenu?.setAttribute('data-open', String(open));
          otherTrigger?.setAttribute('aria-expanded', String(open));
        };

        const closeMenu = () => {
          if (!menu?.open) return;
          menu.close();
        };

        const updateMusicArtwork = async () => {
          if (!musicLink || !musicCover || musicLoaded) return;
          musicLoaded = true;

          const endpoint = musicLink.dataset.spotifyEndpoint;
          if (!endpoint) return;

          try {
            const statusUrl = new URL(endpoint, window.location.href);
            statusUrl.searchParams.set('_', String(Date.now()));
            const response = await fetch(statusUrl, {
              cache: 'no-store',
              headers: { Accept: 'application/json' },
            });
            if (!response.ok) throw new Error(`Spotify status ${response.status}`);
            const data = await response.json();
            const image =
              data?.albumImage ||
              data?.image ||
              data?.artworkUrl ||
              data?.album?.image ||
              data?.album?.images?.[0]?.url ||
              data?.item?.album?.images?.[0]?.url;
            const title = data?.title || data?.track || data?.name || data?.item?.name || 'Spotify album cover';
            const readName = (value) => {
              if (!value) return '';
              if (typeof value === 'string') return value.trim();
              if (Array.isArray(value)) {
                return value
                  .map((item) => readName(item))
                  .filter(Boolean)
                  .join(', ');
              }
              return (value.name || value.title || '').trim();
            };
            const artist = readName(
              data?.artist ||
                data?.artists ||
                data?.item?.artists ||
                data?.album?.artist ||
                data?.album?.artists ||
                data?.item?.album?.artists,
            );
            const album = readName(
              data?.albumName ||
                data?.albumTitle ||
                data?.album?.name ||
                data?.album ||
                data?.item?.album?.name,
            );
            const readImage = (value) => (typeof value === 'string' ? value.trim() : '');
            const loadArtwork = (src) =>
              new Promise((resolve, reject) => {
                const artwork = new Image();
                artwork.decoding = 'async';
                artwork.onload = () => {
                  const decode = typeof artwork.decode === 'function' ? artwork.decode() : Promise.resolve();
                  decode.catch(() => {}).then(resolve);
                };
                artwork.onerror = reject;
                artwork.src = src;
              });
            const readTime = (value) => {
              if (!value) return null;
              if (typeof value === 'number') return new Date(value < 1e12 ? value * 1000 : value);
              const parsed = new Date(value);
              return Number.isNaN(parsed.getTime()) ? null : parsed;
            };
            const playedAt = readTime(
              data?.playedAt ||
                data?.played_at ||
                data?.lastPlayedAt ||
                data?.last_played_at ||
                data?.timestamp ||
                data?.item?.played_at,
            );
            const relativePlayed = (() => {
              if (data?.isPlaying || data?.is_playing || data?.currentlyPlaying) return 'Now playing';
              if (!playedAt) return '';
              const minutes = Math.max(0, Math.round((Date.now() - playedAt.getTime()) / 60000));
              if (minutes < 1) return 'Just listened';
              if (minutes < 60) return `${minutes} min ago`;
              const hours = Math.round(minutes / 60);
              if (hours < 24) return `${hours} hr ago`;
              const days = Math.round(hours / 24);
              return `${days} day${days === 1 ? '' : 's'} ago`;
            })();
            const artworkSrc = readImage(image);

            if (artworkSrc) {
              const requestId = ++musicArtworkRequest;
              await loadArtwork(artworkSrc);
              if (requestId !== musicArtworkRequest) return;

              musicCover.src = artworkSrc;
              musicCover.alt = title;
              if (musicTitle) musicTitle.textContent = title;
              if (musicArtist && artist) musicArtist.textContent = artist;
              if (musicAlbum && album) musicAlbum.textContent = album;
              if (musicPlayed && relativePlayed) {
                musicPlayed.textContent = relativePlayed;
                musicPlayed.hidden = false;
              }
              musicLink.setAttribute(
                'aria-label',
                ['Open on Spotify', title, artist, album, relativePlayed].filter(Boolean).join(' — '),
              );
              requestAnimationFrame(() => {
                if (requestId === musicArtworkRequest) musicLink.classList.add('is-art-loaded');
              });
            }
          } catch (_) {
            musicLoaded = false;
          }
        };

        menuToggle?.addEventListener('click', () => {
          if (!menu || typeof menu.showModal !== 'function') return;
          menu.showModal();
          menu.focus({ preventScroll: true });
          menuToggle.setAttribute('aria-expanded', 'true');
          document.body.classList.add('menu-open');
          updateMusicArtwork();
        });

        menuClose?.addEventListener('click', closeMenu);
        otherTrigger?.addEventListener('click', () => {
          setOtherMenuOpen(otherMenu?.getAttribute('data-open') !== 'true');
        });
        menu?.addEventListener('click', (event) => {
          if (event.target === menu) closeMenu();
        });
        menu?.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', closeMenu);
        });
        musicLink?.addEventListener('mouseenter', updateMusicArtwork);
        musicLink?.addEventListener('focus', updateMusicArtwork);
        menu?.addEventListener('close', () => {
          setOtherMenuOpen(false);
          menuToggle?.setAttribute('aria-expanded', 'false');
          document.body.classList.remove('menu-open');
        });

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', renderAll, { once: true });
        } else {
          renderAll();
        }

        let resizeTimer;
        window.addEventListener('resize', () => {
          window.clearTimeout(resizeTimer);
          resizeTimer = window.setTimeout(renderAll, 120);
        });
      })();
    </script>
  </body>
</html>
