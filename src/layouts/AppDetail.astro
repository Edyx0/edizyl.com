---
import Layout from './Layout.astro';
import type { AppData } from '../data/apps';

interface Props {
  app: AppData;
}

const { app } = Astro.props;

const identities = {
  'holy-shift': {
    surface: '#09040f',
    surfaceRaised: '#1a0823',
    ink: '#fff8ff',
    muted: '#d4b9d8',
    accent: '#ff18ae',
    signal: '#ff5a1f',
    finalInk: '#09040f',
    heroArt: '/landing/self-brand/holy-shift-characters-a.webp',
    heroAlt: 'Six pixel-art Holy Shift character cards',
    wordmark: '/holy-shift/logo-hs.svg',
    storyTitle: 'Shift on instinct',
    footerLabel: 'ENTER THE RIFT',
  },
  'tabu-ekstra': {
    surface: '#eeeeec',
    surfaceRaised: '#fffdf8',
    ink: '#151412',
    muted: '#5c554c',
    accent: '#ff9619',
    signal: '#A133FF',
    finalInk: '#fffdf8',
    heroArt: '/landing/self-brand/tabu-ekstra.webp',
    heroAlt: 'Tabum Ekstra wordmark with a fan of orange game cards',
    wordmark: '',
    storyTitle: 'Do not say the obvious',
    footerLabel: 'DRAW A CARD',
  },
  imposter: {
    surface: '#25090b',
    surfaceRaised: '#3a0c10',
    ink: '#fff1d8',
    muted: '#d7bea0',
    accent: '#cda45b',
    signal: '#a51820',
    finalInk: '#fff1d8',
    heroArt: '/landing/self-brand/imposter.webp',
    heroAlt: 'A suspicious detective framed by a magnifying glass',
    wordmark: '',
    storyTitle: 'Almost everyone knows',
    footerLabel: 'OPEN THE CASE',
  },
} as const;

const identity = identities[app.slug as keyof typeof identities] ?? identities.imposter;
const pageStyle = [
  `--project-surface:${identity.surface}`,
  `--project-raised:${identity.surfaceRaised}`,
  `--project-ink:${identity.ink}`,
  `--project-muted:${identity.muted}`,
  `--project-accent:${identity.accent}`,
  `--project-signal:${identity.signal}`,
  `--project-final-ink:${identity.finalInk}`,
].join(';');
const metricsByApp = {
  'tabu-ekstra': [
    { value: '#8', detail: 'Peak rank in App Store Card Games' },
    { value: '13%', detail: 'Sustained conversion rate' },
    { value: '3500+', detail: 'Active players' },
    { value: '14000+', detail: 'Players reached · February—July' },
    { value: '4.5 ★', detail: 'App Store rating · 36 ratings' },
  ],
} as const;
const tabuMetrics = metricsByApp['tabu-ekstra'];
---

<Layout title={`${app.name} — Ediz Yılmaz`} description={app.tagline} bodyClass="app-project-page">
  <main class={`app-project app-project--${app.slug}`} style={pageStyle} data-app-project>
    <header class="app-project__header">
      <a href="/" class="app-project__back" aria-label="Back to portfolio index">
        Index — Back
      </a>
      <p class="app-project__count" aria-live="polite"><span data-current>01</span> / <span data-total>01</span></p>
    </header>

    <div
      class="app-project__rail"
      data-project-rail
      tabindex="0"
      role="region"
      aria-label={`${app.name} project gallery. Use arrow keys or scroll to explore.`}
    >
      <article class="app-project__panel app-project__panel--hero" data-project-panel>
        <div class="app-project__hero-copy">
          {identity.wordmark ? (
            <>
              <h1 class="sr-only">{app.name}</h1>
              <img class="app-project__wordmark" src={identity.wordmark} alt={app.name} />
            </>
          ) : (
            <h1>{app.name}</h1>
          )}
          <p class="app-project__tagline">{app.tagline}</p>
        </div>
        <figure class="app-project__hero-art">
          <span class="app-project__art-field" aria-hidden="true"></span>
          <img class="app-project__hero-art-primary" src={identity.heroArt} alt={identity.heroAlt} fetchpriority="high" />
          {app.slug === 'holy-shift' && (
            <img
              class="app-project__hero-art-secondary"
              src="/landing/self-brand/holy-shift-characters-b.webp"
              alt=""
              fetchpriority="high"
            />
          )}
        </figure>
        <p class="app-project__scroll-note" aria-hidden="true">Scroll to explore <span>→</span></p>
      </article>

      {app.screenshots[0] && (
        <figure class="app-project__panel app-project__panel--shot app-project__panel--shot-lead" data-project-panel>
          <span class="app-project__shot-number" aria-hidden="true">01</span>
          <img src={app.screenshots[0]} alt={`${app.name} App Store screenshot 1`} loading="eager" />
          <figcaption>{app.subtitle}</figcaption>
        </figure>
      )}

      <article class="app-project__panel app-project__panel--story" data-project-panel>
        <h2>{identity.storyTitle}</h2>
        <div class="app-project__story-copy">
          {app.about.slice(0, 2).map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </article>

      {app.screenshots.slice(1, 3).map((screenshot, index) => (
        <figure class={`app-project__panel app-project__panel--shot app-project__panel--shot-${index + 2}`} data-project-panel>
          <span class="app-project__shot-number" aria-hidden="true">{String(index + 2).padStart(2, '0')}</span>
          <img src={screenshot} alt={`${app.name} App Store screenshot ${index + 2}`} loading="lazy" />
          <figcaption>{app.features[index] ?? app.subtitle}</figcaption>
        </figure>
      ))}

      {app.slug === 'tabu-ekstra' && (
        <article class="app-project__panel app-project__panel--features" data-project-panel>
          <div class="app-project__features-head">
            <h2>Real traction</h2>
          </div>
          <ol class="app-project__feature-list">
            {tabuMetrics.map(({ value, detail }) => (
              <li class="app-project__metric">
                <strong>{value}</strong>
                <p>{detail}</p>
              </li>
            ))}
          </ol>
        </article>
      )}

      {app.slug === 'tabu-ekstra' && (
        <section
          class="app-project__panel app-project__panel--seasonal"
          data-project-panel
          aria-labelledby="seasonal-decks-title"
        >
          <header class="app-project__seasonal-head">
            <h2 id="seasonal-decks-title">Words change with the room.</h2>
            <p>Seasonal decks keep the game current without changing the one-phone rhythm.</p>
          </header>
          <div class="app-project__seasonal-decks">
            <figure class="app-project__seasonal-deck app-project__seasonal-deck--summer">
              <img
                src="/landing/self-brand/summer-words.webp"
                alt="Summer Words event artwork for Tabum Ekstra"
                loading="lazy"
              />
              <figcaption><strong>Summer Words</strong><span>2026</span></figcaption>
            </figure>
            <figure class="app-project__seasonal-deck app-project__seasonal-deck--ramadan">
              <img
                src="/tabu-ekstra/ramadantabu.webp"
                alt="Ramadan event artwork for Tabum Ekstra"
                loading="lazy"
              />
              <figcaption><strong>Ramadan deck</strong><span>2026</span></figcaption>
            </figure>
          </div>
        </section>
      )}

      {app.screenshots.slice(3).map((screenshot, index) => (
        <figure class={`app-project__panel app-project__panel--shot app-project__panel--shot-${index + 4}`} data-project-panel>
          <span class="app-project__shot-number" aria-hidden="true">{String(index + 4).padStart(2, '0')}</span>
          <img src={screenshot} alt={`${app.name} App Store screenshot ${index + 4}`} loading="lazy" />
          <figcaption>{app.features[index + 2] ?? app.subtitle}</figcaption>
        </figure>
      ))}

      <article class="app-project__panel app-project__panel--final" data-project-panel>
        <img class="app-project__final-icon" src={app.icon} alt="" width="144" height="144" loading="lazy" />
        <p>{identity.footerLabel}</p>
        <h2>{app.name}</h2>
        <div class="app-project__final-actions">
          <a href={app.appStoreUrl} target="_blank" rel="noreferrer">View on the App Store <span aria-hidden="true">↗</span></a>
          <a href={`/${app.slug}/privacy/`}>Privacy</a>
        </div>
      </article>
    </div>

    <div class="app-project__progress" aria-hidden="true"><span data-project-progress></span></div>
  </main>
</Layout>

<script>
  const projects = document.querySelectorAll<HTMLElement>('[data-app-project]');

  projects.forEach((project) => {
    const rail = project.querySelector<HTMLElement>('[data-project-rail]');
    const panels = [...project.querySelectorAll<HTMLElement>('[data-project-panel]')];
    const progress = project.querySelector<HTMLElement>('[data-project-progress]');
    const current = project.querySelector<HTMLElement>('[data-current]');
    const total = project.querySelector<HTMLElement>('[data-total]');
    if (!rail || panels.length === 0) return;

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
    let dragging = false;
    let dragStartX = 0;
    let dragStartScroll = 0;

    if (total) total.textContent = String(panels.length).padStart(2, '0');

    const updateChrome = () => {
      const max = Math.max(1, rail.scrollWidth - rail.clientWidth);
      const ratio = Math.min(1, Math.max(0, rail.scrollLeft / max));
      if (progress) progress.style.transform = `scaleX(${ratio})`;

      const center = rail.scrollLeft + rail.clientWidth / 2;
      let activeIndex = 0;
      let closest = Number.POSITIVE_INFINITY;
      panels.forEach((panel, index) => {
        const panelCenter = panel.offsetLeft + panel.offsetWidth / 2;
        const distance = Math.abs(center - panelCenter);
        if (distance < closest) {
          closest = distance;
          activeIndex = index;
        }
      });
      if (current) current.textContent = String(activeIndex + 1).padStart(2, '0');
      panels.forEach((panel, index) => panel.toggleAttribute('data-active', index === activeIndex));
    };

    project.addEventListener('wheel', (event) => {
      const rawDelta = Math.abs(event.deltaY) > Math.abs(event.deltaX) ? event.deltaY : event.deltaX;
      if (!rawDelta) return;
      event.preventDefault();
      const unit = event.deltaMode === WheelEvent.DOM_DELTA_LINE
        ? 32
        : event.deltaMode === WheelEvent.DOM_DELTA_PAGE
          ? rail.clientWidth
          : 1;
      const delta = rawDelta * unit;
      const max = Math.max(0, rail.scrollWidth - rail.clientWidth);
      rail.scrollLeft = Math.min(max, Math.max(0, rail.scrollLeft + delta));
      updateChrome();
    }, { passive: false });

    rail.addEventListener('pointerdown', (event) => {
      if (event.pointerType === 'touch') return;
      if (event.target instanceof Element && event.target.closest('a, button, input, select, textarea')) return;
      dragging = true;
      dragStartX = event.clientX;
      dragStartScroll = rail.scrollLeft;
      rail.setPointerCapture(event.pointerId);
      project.setAttribute('data-dragging', '');
    });

    rail.addEventListener('pointermove', (event) => {
      if (!dragging) return;
      const next = dragStartScroll - (event.clientX - dragStartX);
      rail.scrollLeft = next;
      updateChrome();
    });

    const endDrag = (event: PointerEvent) => {
      if (!dragging) return;
      dragging = false;
      project.removeAttribute('data-dragging');
      if (rail.hasPointerCapture(event.pointerId)) rail.releasePointerCapture(event.pointerId);
    };

    rail.addEventListener('pointerup', endDrag);
    rail.addEventListener('pointercancel', endDrag);
    rail.addEventListener('scroll', updateChrome, { passive: true });

    rail.addEventListener('keydown', (event) => {
      if (event.key !== 'ArrowRight' && event.key !== 'ArrowLeft') return;
      event.preventDefault();
      const direction = event.key === 'ArrowRight' ? 1 : -1;
      rail.scrollBy({ left: rail.clientWidth * 0.72 * direction, behavior: reducedMotion.matches ? 'auto' : 'smooth' });
    });

    window.addEventListener('resize', updateChrome, { passive: true });
    updateChrome();
  });
</script>

<style>
  :global(body.app-project-page) {
    margin: 0;
    overflow: hidden;
    background: var(--project-surface, #111);
  }

  :global(body.app-project-page > .grain),
  :global(body.app-project-page > .site) {
    display: none;
  }

  .app-project {
    position: fixed;
    z-index: 20;
    inset: 0;
    width: 100vw;
    max-width: none;
    height: 100svh;
    margin: 0;
    padding: 0;
    overflow: hidden;
    color: var(--project-ink);
    background: var(--project-surface);
    font-family: 'Schibsted Grotesk', Arial, sans-serif;
    cursor: grab;
  }

  .app-project[data-dragging] { cursor: grabbing; }

  .app-project__header {
    position: fixed;
    z-index: 8;
    inset: 0 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: 4.5rem;
    padding: 0 clamp(1rem, 2.2vw, 2.25rem);
    color: var(--project-ink);
    mix-blend-mode: normal;
    pointer-events: none;
  }

  .app-project__header a { pointer-events: auto; }
  .app-project__back,
  .app-project__running-title,
  .app-project__count {
    margin: 0;
    color: var(--project-ink);
    font-family: 'Helvetica Now Display', 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(1rem, 2vw, 1.75rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.01em;
  }
  .app-project__back {
    color: inherit;
    text-decoration: none;
    background-image: none;
  }
  .app-project--tabu-ekstra .app-project__back:hover,
  .app-project--tabu-ekstra .app-project__back:focus-visible {
    color: #a133ff;
  }
  .app-project--tabu-ekstra .app-project__running-title {
    color: #a133ff;
    background: #fffdf8;
    font-family: 'Anton', Impact, sans-serif;
    font-weight: 400;
    letter-spacing: 0.04em;
    padding: 0.28rem 0.55rem;
    text-transform: uppercase;
  }
  .app-project--tabu-ekstra .app-project__count { padding: 0.28rem 0.5rem; color: #a133ff; background: #fffdf8; }
  .app-project__running-title { justify-self: center; }
  .app-project__count { justify-self: end; font-variant-numeric: tabular-nums; }

  .app-project__rail {
    display: flex;
    width: 100%;
    height: 100%;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: none;
    overscroll-behavior-x: contain;
    scroll-snap-type: none;
    touch-action: pan-x;
  }
  .app-project__rail::-webkit-scrollbar { display: none; }
  .app-project__rail:focus-visible { outline: 2px solid var(--project-accent); outline-offset: -4px; }

  .app-project__panel {
    position: relative;
    flex: 0 0 auto;
    height: 100%;
    margin: 0;
    overflow: hidden;
    scroll-snap-align: start;
  }

  .app-project__panel--hero {
    display: grid;
    grid-template-columns: minmax(20rem, 0.92fr) minmax(24rem, 1.08fr);
    align-items: center;
    width: 100vw;
    min-width: 100vw;
    padding: clamp(6rem, 10vh, 8rem) clamp(1.25rem, 5vw, 5.5rem) clamp(3.5rem, 6vh, 5rem);
    background: var(--project-surface);
  }

  .app-project--tabu-ekstra .app-project__panel--hero {
    background-color: #e8e5ea;
    background-image: url('/tabu-ekstra/apbg-collage.jpg');
    background-position: center top;
    background-repeat: repeat;
    background-size: clamp(25.5rem, 36vw, 34.5rem) auto;
  }

  .app-project__hero-copy { position: relative; z-index: 2; max-width: 43rem; }
  .app-project__chapter,
  .app-project__story-index,
  .app-project__features-head > p {
    margin: 0 0 1.2rem;
    font-size: clamp(0.75rem, 1vw, 0.95rem);
    font-weight: 750;
    letter-spacing: 0.05em;
  }
  .app-project__chapter { color: var(--project-muted); }
  .app-project__story-index,
  .app-project__features-head > p { color: currentColor; }

  .app-project__hero-copy h1 {
    max-width: 10ch;
    margin: 0;
    font-size: clamp(4.2rem, 9vw, 6rem);
    line-height: 0.88;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }
  .app-project__wordmark { display: block; width: min(34rem, 86%); max-height: 16rem; object-fit: contain; object-position: left center; }
  .app-project--holy-shift .app-project__wordmark { width: min(27.2rem, 68.8%); max-height: 12.8rem; }
  .app-project__tagline {
    max-width: 32rem;
    margin: clamp(1.5rem, 4vh, 3rem) 0 1.5rem;
    color: var(--project-muted);
    font-size: clamp(1.08rem, 1.6vw, 1.45rem);
    line-height: 1.35;
    text-wrap: pretty;
  }
  .app-project__store-link,
  .app-project__final-actions a {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    min-height: 3rem;
    padding: 0.75rem 1rem;
    color: var(--project-surface);
    background: var(--project-accent);
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    transition: transform 240ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .app-project__store-link:hover,
  .app-project__final-actions a:hover { transform: translateY(-0.2rem); }

  .app-project__hero-art {
    position: relative;
    align-self: stretch;
    margin: 0;
  }
  .app-project__hero-art img {
    position: absolute;
    z-index: 2;
    inset: 50% auto auto 50%;
    width: min(43vw, 44rem);
    height: min(80vh, 52rem);
    object-fit: contain;
    transform: translate(-45%, -47%) rotate(2deg);
    filter: drop-shadow(0 0.5rem 0.35rem rgb(0 0 0 / 0.22));
  }
  .app-project__art-field {
    position: absolute;
    inset: 12% 5% 8% 8%;
    background: var(--project-raised);
    transform: rotate(-3deg);
  }
  .app-project__scroll-note {
    position: absolute;
    z-index: 3;
    right: clamp(1.25rem, 3vw, 3rem);
    bottom: 1.4rem;
    margin: 0;
    color: var(--project-ink);
    font-size: 0.75rem;
    font-weight: 700;
  }
  .app-project__scroll-note span { color: var(--project-accent); font-size: 1rem; }

  .app-project__panel--shot {
    display: grid;
    grid-template-rows: minmax(0, auto) auto;
    place-items: center;
    align-content: center;
    row-gap: clamp(0.9rem, 1.8vh, 1.35rem);
    width: clamp(19rem, 34vw, 32rem);
    padding: clamp(5.5rem, 9vh, 7rem) clamp(1.25rem, 2.4vw, 2.5rem) clamp(2.5rem, 4vh, 3.5rem);
    background: var(--project-raised);
  }
  .app-project__panel--shot:nth-of-type(even) { background: var(--project-surface); }
  .app-project__panel--shot img {
    width: auto;
    height: min(68vh, 44rem);
    max-width: 100%;
    object-fit: contain;
    transform: translate3d(var(--shot-x, 0), var(--shot-y, 0), 0) rotate(var(--shot-rotate, 0deg)) scale(1);
    transition: transform 760ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .app-project__panel--shot:not([data-active]) img {
    transform: translate3d(var(--shot-x, 0), var(--shot-y, 0), 0) rotate(var(--shot-rotate, 0deg)) scale(0.94);
  }
  .app-project__panel--shot figcaption {
    width: 100%;
    margin: 0;
    color: var(--project-muted);
    font-size: 0.78rem;
    font-weight: 650;
    line-height: 1.35;
    text-align: center;
    transform: translate3d(var(--caption-x, 0), var(--caption-y, 0), 0) rotate(var(--caption-rotate, 0deg));
    transition: transform 520ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .app-project__shot-number {
    position: absolute;
    top: 5.2rem;
    left: 1.5rem;
    color: var(--project-accent);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .app-project__panel--story,
  .app-project__panel--features,
  .app-project__panel--final {
    width: clamp(34rem, 58vw, 60rem);
    padding: clamp(7rem, 13vh, 10rem) clamp(3rem, 7vw, 7rem) 5rem;
  }
  .app-project__panel--story {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background: var(--project-accent);
    color: var(--project-surface);
  }
  .app-project__panel--story h2,
  .app-project__features-head h2,
  .app-project__panel--final h2 {
    max-width: 13ch;
    margin: 0;
    font-size: clamp(2.8rem, 5.5vw, 5.2rem);
    line-height: 0.97;
    letter-spacing: -0.035em;
    text-wrap: balance;
  }
  .app-project__story-copy {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.5rem, 4vw, 4rem);
    margin-top: clamp(2rem, 6vh, 4.5rem);
    font-size: clamp(0.96rem, 1.2vw, 1.12rem);
    line-height: 1.55;
  }
  .app-project__story-copy p {
    margin: 0;
    color: inherit;
    font: inherit;
  }
  .app-project__meta-line {
    position: static;
    max-width: 60ch;
    margin: clamp(1.5rem, 4vh, 3rem) 0 0;
    padding-top: 1rem;
    border-top: 1px solid currentColor;
    color: inherit;
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .app-project__panel--features { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 4rem; background: var(--project-surface); }
  .app-project__features-head h2 { font-size: clamp(2.7rem, 4.6vw, 4.6rem); }
  .app-project__feature-list { align-self: center; margin: 0; padding: 0; list-style: none; }
  .app-project__feature-list li {
    display: grid;
    grid-template-columns: 2.2rem 1fr;
    gap: 1rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--project-ink) 28%, transparent);
  }
  .app-project__feature-list li:first-child { border-top: 1px solid color-mix(in srgb, var(--project-ink) 28%, transparent); }
  .app-project__feature-list span { color: var(--project-accent); font-size: 0.72rem; font-weight: 800; }
  .app-project__feature-list p {
    margin: 0;
    color: var(--project-ink);
    font-size: 0.98rem;
    line-height: 1.35;
  }

  .app-project__panel--final {
    display: flex;
    width: min(82vw, 76rem);
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    color: var(--project-final-ink);
    background: var(--project-signal);
  }
  .app-project__final-icon { width: 5.5rem; height: 5.5rem; margin-bottom: 2rem; border-radius: 1.25rem; }
  .app-project__panel--final > p { margin: 0 0 0.9rem; color: inherit; font-size: 0.78rem; font-weight: 850; letter-spacing: 0.08em; }
  .app-project__panel--final h2 { max-width: none; font-size: clamp(4rem, 9vw, 6rem); }
  .app-project__final-actions { display: flex; flex-wrap: wrap; gap: 0.8rem; margin-top: 2.5rem; }
  .app-project__final-actions a { color: var(--project-surface); background: var(--project-ink); }
