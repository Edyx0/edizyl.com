---
import Layout from './Layout.astro';
import type { AppData } from '../data/apps';

interface Props {
  app: AppData;
}

const { app } = Astro.props;
const appColor = {
  'tabu-ekstra': { surface: '#6f35a1', ink: '#ffffff' },
  imposter: { surface: '#c89446', ink: '#191817' },
  'holy-shift': { surface: '#b81486', ink: '#fff5fb' },
}[app.slug] ?? { surface: app.accent, ink: '#191817' };
const heroStyle = `--app-accent: ${app.accent}; --app-accent-surface: ${appColor.surface}; --app-accent-ink: ${appColor.ink};`;
---

<Layout title={`${app.name} — ${app.subtitle}`} description={app.tagline} bodyClass="app-detail-page">
  <div class="app-detail-shell" style={heroStyle} data-app={app.slug}>
  <a href="/" class="back-link app-detail__back">Index — Back</a>

  <section class="app-hero">
    <div class="app-hero-glow"></div>
    <div class="app-hero-content">
      <img src={app.icon} alt={`${app.name} icon`} class="app-hero-icon" width="120" height="120" />
      <div class="app-hero-text">
        <h1>{app.name}</h1>
        <p class="hero-sub">{app.subtitle}</p>
        <p class="hero-tagline">{app.tagline}</p>
        <p class="app-hero-note">{app.short}</p>
        <p>
          <a href={app.appStoreUrl} class="cta">Download on the App Store →</a>
        </p>
      </div>
    </div>

    {app.stats && app.stats.length > 0 && (
      <div class="stat-pills">
        {app.stats.map((s) => (
          <div class="stat-pill">
            <span class="stat-label">{s.label}</span>
            <span class="stat-value">{s.value}</span>
          </div>
        ))}
      </div>
    )}
  </section>

  {(app.screenshots.length > 0 || app.previewVideoHls) && (
    <section class="section-screenshots app-gallery">
      <div class="app-gallery__header">
        <p>Selected screens</p>
        <h2>Screenshots</h2>
      </div>
      <div class="app-gallery__motion" aria-hidden="true">
        <span>Scroll / drag</span>
        <span class="app-gallery__progress"><span data-gallery-progress></span></span>
      </div>
      <div
        class="shots-scroll"
        data-smooth-gallery
        tabindex="0"
        role="region"
        aria-label={`${app.name} screenshot gallery`}
      >
        {app.previewVideoHls && (
          <video
            class="shot-video"
            controls
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            poster={app.previewVideoPoster}
            data-hls={app.previewVideoHls}
          ></video>
        )}
        {app.screenshots.map((src, i) => (
          <img src={src} alt={`${app.name} screenshot ${i + 1}`} loading="lazy" />
        ))}
      </div>
    </section>
  )}

  <script>
    const videos = document.querySelectorAll('video[data-hls]');
    videos.forEach(async (video) => {
      const v = video as HTMLVideoElement;
      const src = v.dataset.hls;
      if (!src) return;
      v.muted = true;
      v.autoplay = true;
      v.loop = true;
      const playWhenReady = () => {
        v.play().catch(() => {
          // Autoplay can still be blocked by browser settings; controls remain available.
        });
      };
      if (v.canPlayType('application/vnd.apple.mpegurl')) {
        v.src = src;
        v.addEventListener('loadedmetadata', playWhenReady, { once: true });
        return;
      }
      // Load hls.js on demand for Chrome/Firefox
      if (!(window as any).Hls) {
        await new Promise<void>((resolve, reject) => {
          const s = document.createElement('script');
          s.src = 'https://cdn.jsdelivr.net/npm/hls.js@1.5.18/dist/hls.min.js';
          s.onload = () => resolve();
          s.onerror = () => reject();
          document.head.appendChild(s);
        });
      }
      const Hls = (window as any).Hls;
      if (Hls && Hls.isSupported()) {
        const hls = new Hls();
        hls.loadSource(src);
        hls.attachMedia(v);
        hls.on(Hls.Events.MANIFEST_PARSED, playWhenReady);
      }
    });

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    document.querySelectorAll<HTMLElement>('[data-smooth-gallery]').forEach((track) => {
      const gallery = track.closest<HTMLElement>('.app-gallery');
      const progress = gallery?.querySelector<HTMLElement>('[data-gallery-progress]');
      let target = track.scrollLeft;
      let frame = 0;
      let dragging = false;
      let startX = 0;
      let startScroll = 0;
      let lastX = 0;
      let lastTime = 0;
      let velocity = 0;

      const maxScroll = () => Math.max(0, track.scrollWidth - track.clientWidth);
      const clamp = (value: number) => Math.min(maxScroll(), Math.max(0, value));
      const updateProgress = () => {
        const max = maxScroll();
        const amount = max > 0 ? track.scrollLeft / max : 0;
        progress?.style.setProperty('transform', `scaleX(${Math.max(0.035, amount)})`);
      };

      const glide = () => {
        const distance = target - track.scrollLeft;
        if (reducedMotion.matches || Math.abs(distance) < 0.35) {
          track.scrollLeft = target;
          frame = 0;
          updateProgress();
          return;
        }
        track.scrollLeft += distance * 0.105;
        updateProgress();
        frame = requestAnimationFrame(glide);
      };

      const moveTo = (value: number) => {
        target = clamp(value);
        if (reducedMotion.matches) {
          track.scrollLeft = target;
          updateProgress();
          return;
        }
        if (!frame) frame = requestAnimationFrame(glide);
      };

      track.addEventListener('wheel', (event) => {
        const delta = Math.abs(event.deltaX) > Math.abs(event.deltaY) ? event.deltaX : event.deltaY;
        const max = maxScroll();
        const atStart = target <= 0.5 || track.scrollLeft <= 0.5;
        const atEnd = target >= max - 0.5 || track.scrollLeft >= max - 0.5;
        if (!max || (delta < 0 && atStart) || (delta > 0 && atEnd)) return;
        event.preventDefault();
        moveTo(target + delta * 1.15);
      }, { passive: false });

      track.addEventListener('pointerdown', (event) => {
        if (event.pointerType !== 'mouse') return;
        if ((event.target as HTMLElement).closest('video, button, a')) return;
        dragging = true;
        if (frame) cancelAnimationFrame(frame);
        frame = 0;
        target = track.scrollLeft;
        startX = lastX = event.clientX;
        startScroll = track.scrollLeft;
        lastTime = performance.now();
        velocity = 0;
        track.classList.add('is-dragging');
        track.setPointerCapture(event.pointerId);
      });

      track.addEventListener('pointermove', (event) => {
        if (!dragging) return;
        const now = performance.now();
        const elapsed = Math.max(1, now - lastTime);
        velocity = (lastX - event.clientX) / elapsed;
        target = clamp(startScroll - (event.clientX - startX));
        track.scrollLeft = target;
        lastX = event.clientX;
        lastTime = now;
        updateProgress();
      });

      const release = (event: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        track.classList.remove('is-dragging');
        if (track.hasPointerCapture(event.pointerId)) track.releasePointerCapture(event.pointerId);
        moveTo(track.scrollLeft + velocity * 240);
      };

      track.addEventListener('pointerup', release);
      track.addEventListener('pointercancel', release);
      track.addEventListener('keydown', (event) => {
        if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
        event.preventDefault();
        const direction = event.key === 'ArrowRight' ? 1 : -1;
        moveTo(target + track.clientWidth * 0.72 * direction);
      });
      track.addEventListener('scroll', () => {
        if (!frame && !dragging) target = track.scrollLeft;
        updateProgress();
      }, { passive: true });
      window.addEventListener('resize', () => {
        target = clamp(target);
        updateProgress();
      }, { passive: true });

      updateProgress();
    });
  </script>

  <section class="app-section app-section--about">
    <h2>About</h2>
    <div class="app-section__body">{app.about.map((p) => <p>{p}</p>)}</div>
  </section>

  <section class="app-section app-section--features">
    <h2>Features</h2>
    <div class="app-section__body">
      <ul class="list">
        {app.features.map((f) => <li>{f}</li>)}
      </ul>
    </div>
  </section>

  <section class="app-section app-section--build">
    <h2>How it was built?</h2>
    <div class="app-section__body">
      {app.builtStory.map((p) => <p>{p}</p>)}

      <div class="chips">
        {app.techChips.map((c) => <span class="chip">{c}</span>)}
      </div>

      <details class="tech-details">
        <summary>Full tech stack</summary>
        <dl class="stack">
          {app.stack.map((s) => (
            <>
              <dt>{s.label}</dt>
              <dd>{s.value}</dd>
            </>
          ))}
        </dl>
      </details>
    </div>
  </section>

  {app.highlights && app.highlights.length > 0 && (
    <section class="app-section app-section--highlights">
      <h2>Highlights</h2>
      <div class="app-section__body">
        <ul class="list">
          {app.highlights.map((h) => <li>{h}</li>)}
        </ul>
      </div>
    </section>
  )}

  <section class="app-section app-section--technical">
    <h2>Technical details</h2>
    <div class="app-section__body">
      <div class="meta-grid">
        <div><span class="muted">Version</span><br />{app.meta.version}</div>
        <div><span class="muted">Released</span><br />{app.meta.released}</div>
        <div><span class="muted">Updated</span><br />{app.meta.updated}</div>
        <div><span class="muted">Requires</span><br />{app.meta.minOS}</div>
        <div><span class="muted">Size</span><br />{app.meta.size}</div>
        <div><span class="muted">Genre</span><br />{app.meta.genre}</div>
        {app.meta.rating && <div><span class="muted">Rating</span><br />{app.meta.rating}</div>}
      </div>
    </div>
  </section>

  <section class="bottom-cta app-final">
    <h2>Try it</h2>
    <p>{app.tagline}</p>
    <p>
      <a href={app.appStoreUrl} class="cta">Get {app.name} on the App Store →</a>
    </p>
    <p class="muted" style="margin-top: 1rem;">
      See the <a href={`/${app.slug}/privacy`}>{app.name} privacy policy</a>.
    </p>
  </section>
  </div>

</Layout>
