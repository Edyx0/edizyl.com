---
import Layout from './Layout.astro';
import type { AppData } from '../data/apps';

interface Props {
  app: AppData;
}

const { app } = Astro.props;
const isTabuEkstra = app.slug === 'tabu-ekstra';
const isRebuiltMenuApp = app.slug === 'imposter' || app.slug === 'holy-shift';
const usesBrandedMasthead = isTabuEkstra || isRebuiltMenuApp;
const showsStandardAppSections = !isTabuEkstra && app.slug !== 'imposter' && app.slug !== 'holy-shift';
const showsShowcaseCards = true;
const presentation = {
  'tabu-ekstra': {
    title: 'Tabum Ekstra',
    wordmark: '',
    wordmarkAlt: '',
    art: '',
    artAlt: '',
    ctaLabel: 'App Store',
  },
  imposter: {
    title: 'Imposter',
    wordmark: '',
    wordmarkAlt: '',
    art: '/landing/self-brand/imposter.webp',
    artAlt: 'Imposter character artwork',
    ctaLabel: 'App Store',
    showcaseTitle: 'Bluff, read, vote',
    showcaseIntro: 'A single-phone party loop built around private role reveals, careful clues, and a vote that turns every weak answer into evidence.',
    cards: [
      { title: 'Private reveal', text: 'Press-and-hold role cards keep the secret hidden while the phone moves player to player.' },
      { title: 'Clue pressure', text: 'Everyone talks around the same word while the imposter improvises without giving themselves away.' },
      { title: 'Table vote', text: 'The round closes with suspicion, discussion, and a group vote before the imposter can blend in.' },
    ],
  },
  'holy-shift': {
    title: 'Holy Shift',
    wordmark: '/holy-shift/logo-hs.svg',
    wordmarkAlt: 'Holy Shift',
    art: '/landing/self-brand/holy-shift-characters-a.webp',
    altArt: '/landing/self-brand/holy-shift-characters-b.webp',
    artAlt: 'Holy Shift neon character artwork',
    ctaLabel: 'App Store',
    showcaseTitle: 'Reflex system',
    showcaseIntro: 'Holy Shift keeps the Tabu-style page rhythm but switches the energy to arcade pressure: color shifting, anomaly bursts, multipliers, and unlockable skins.',
    cards: [
      { title: 'RIFT anomaly', text: 'Sudden speed bursts destabilize the run and force instant color decisions.' },
      { title: 'Shield & Strike', text: 'Risk windows let players charge multipliers while the screen is at its most volatile.' },
      { title: 'Sparks shop', text: 'Runs feed an unlock loop with skins earned through in-game sparks.' },
    ],
  },
}[app.slug];
const appColor = {
  'tabu-ekstra': { surface: '#6f35a1', ink: '#ffffff' },
  imposter: { surface: '#c89446', ink: '#191817' },
  'holy-shift': { surface: '#b81486', ink: '#fff5fb' },
}[app.slug] ?? { surface: app.accent, ink: '#191817' };
const heroStyle = `--app-accent: ${app.accent}; --app-accent-surface: ${appColor.surface}; --app-accent-ink: ${appColor.ink};`;
---

<Layout title={`${app.name} — Ediz Yılmaz`} description={app.tagline} bodyClass="app-detail-page">
  <div class="app-detail-shell" style={heroStyle} data-app={app.slug}>
  <a href="/" class="back-link app-detail__back">Index — Back</a>

  {usesBrandedMasthead && (
    <section class={`tabu-top app-top app-top--${app.slug}`} aria-label={`${app.name} masthead`}>
      {presentation?.art && (
        <img src={presentation.art} alt={presentation.artAlt} class="app-top__art" width="900" height="900" />
      )}
      {presentation?.altArt && (
        <img src={presentation.altArt} alt="" class="app-top__art app-top__art--alt" width="900" height="1800" />
      )}
      <div class="tabu-top__inner">
        {presentation?.wordmark ? (
          <div class="app-top__wordmark-wrap">
            <h2 class="sr-only">{presentation?.title ?? app.name}</h2>
            <img
              src={presentation.wordmark}
              alt={presentation.wordmarkAlt}
              class="app-top__wordmark"
              width="687"
              height="332"
            />
          </div>
        ) : (
          <h2>{presentation?.title ?? app.name}</h2>
        )}
        <div class="app-top__store-stack">
          <img src={app.icon} alt="" class="tabu-top__logo" width="120" height="120" />
          <a href={app.appStoreUrl} class="tabu-final__link" aria-label={`Open ${app.name} on the App Store`}>
            {presentation?.ctaLabel ?? 'App Store'}
          </a>
        </div>
      </div>
    </section>
  )}

  {!usesBrandedMasthead && (
    <section class="app-hero">
      <div class="app-hero-glow"></div>
      <div class="app-hero-content">
        <img src={app.icon} alt={`${app.name} icon`} class="app-hero-icon" width="120" height="120" />
        <div class="app-hero-text">
          <h1>{app.name}</h1>
          <p class="hero-sub">{app.subtitle}</p>
          <p class="hero-tagline">{app.tagline}</p>
          <p class="app-hero-note">{app.short}</p>
          <p>
            <a href={app.appStoreUrl} class="cta">Download on the App Store →</a>
          </p>
        </div>
      </div>

      {app.stats && app.stats.length > 0 && (
        <div class="stat-pills">
          {app.stats.map((s) => (
            <div class="stat-pill">
              <span class="stat-label">{s.label}</span>
              <span class="stat-value">{s.value}</span>
            </div>
          ))}
        </div>
      )}
    </section>
  )}

  {(app.screenshots.length > 0 || app.previewVideoHls) && (
    <section class="section-screenshots app-gallery">
      {!isTabuEkstra && !['imposter', 'holy-shift'].includes(app.slug) && (
        <div class="app-gallery__header">
          <h2>Screenshots</h2>
        </div>
      )}
      <div
        class="shots-scroll"
        data-smooth-gallery
        tabindex="0"
        role="region"
        aria-label={`${app.name} screenshot gallery`}
      >
        <div class="shots-scroll__track" data-gallery-track>
          {app.previewVideoHls && (
            <video
              class="shot-video"
              controls
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster={app.previewVideoPoster}
              data-hls={app.previewVideoHls}
            ></video>
          )}
          {app.screenshots.map((src, i) => (
            <img
              src={src}
              alt={`${app.name} screenshot ${i + 1}`}
              width="600"
              height="1299"
              loading="eager"
              decoding="async"
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <script>
    const videos = document.querySelectorAll('video[data-hls]');
    videos.forEach(async (video) => {
      const v = video as HTMLVideoElement;
      const src = v.dataset.hls;
      if (!src) return;
      v.muted = true;
      v.autoplay = true;
      v.loop = true;
      const playWhenReady = () => {
        v.play().catch(() => {
          // Autoplay can still be blocked by browser settings; controls remain available.
        });
      };
      if (v.canPlayType('application/vnd.apple.mpegurl')) {
        v.src = src;
        v.addEventListener('loadedmetadata', playWhenReady, { once: true });
        return;
      }
      // Load hls.js on demand for Chrome/Firefox
      if (!(window as any).Hls) {
        await new Promise<void>((resolve, reject) => {
          const s = document.createElement('script');
          s.src = 'https://cdn.jsdelivr.net/npm/hls.js@1.5.18/dist/hls.min.js';
          s.onload = () => resolve();
          s.onerror = () => reject();
          document.head.appendChild(s);
        });
      }
      const Hls = (window as any).Hls;
      if (Hls && Hls.isSupported()) {
        const hls = new Hls();
        hls.loadSource(src);
        hls.attachMedia(v);
        hls.on(Hls.Events.MANIFEST_PARSED, playWhenReady);
      }
    });

    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    document.querySelectorAll<HTMLElement>('[data-smooth-gallery]').forEach((viewport) => {
      const rail = viewport.querySelector<HTMLElement>('[data-gallery-track]');
      if (!rail) return;

      const usesTransform = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
      let position = usesTransform ? 0 : viewport.scrollLeft;
      let target = position;
      let frame = 0;
      let dragging = false;
      let startX = 0;
      let startScroll = 0;
      let lastX = 0;
      let lastTime = 0;
      let velocity = 0;
      let cachedMaxScroll = 0;

      const maxScroll = () => cachedMaxScroll;
      const hasOverflow = () => maxScroll() > 1;
      const clamp = (value: number) => Math.min(maxScroll(), Math.max(0, value));
      const currentPosition = () => usesTransform ? position : viewport.scrollLeft;
      const renderPosition = (value: number) => {
        position = clamp(value);
        if (usesTransform) rail.style.left = `${-position}px`;
        else viewport.scrollLeft = position;
      };
      const updateOverflowState = () => {
        cachedMaxScroll = Math.max(0, viewport.scrollWidth - viewport.clientWidth);
        const overflow = hasOverflow();
        viewport.dataset.galleryOverflow = overflow ? 'true' : 'false';
        viewport.tabIndex = overflow ? 0 : -1;
        if (!overflow) {
          target = 0;
          renderPosition(0);
        } else {
          target = clamp(currentPosition());
          renderPosition(target);
        }
        return overflow;
      };

      const glide = () => {
        const distance = target - currentPosition();
        if (reducedMotion.matches || Math.abs(distance) < 0.35) {
          renderPosition(target);
          frame = 0;
          return;
        }
        renderPosition(currentPosition() + distance * 0.105);
        frame = requestAnimationFrame(glide);
      };

      const moveTo = (value: number) => {
        target = clamp(value);
        if (reducedMotion.matches) {
          renderPosition(target);
          return;
        }
        if (!frame) frame = requestAnimationFrame(glide);
      };

      const handlePointerMove = (event: PointerEvent) => {
        if (!dragging) return;
        const now = performance.now();
        const elapsed = Math.max(1, now - lastTime);
        velocity = (lastX - event.clientX) / elapsed;
        target = clamp(startScroll - (event.clientX - startX));
        renderPosition(target);
        lastX = event.clientX;
        lastTime = now;
      };

      const release = (event: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        viewport.classList.remove('is-dragging');
        if (viewport.hasPointerCapture(event.pointerId)) viewport.releasePointerCapture(event.pointerId);
        viewport.removeEventListener('pointermove', handlePointerMove);
        viewport.removeEventListener('pointerup', release);
        viewport.removeEventListener('pointercancel', release);
        moveTo(currentPosition() + velocity * 240);
      };

      viewport.addEventListener('pointerdown', (event) => {
        if (!updateOverflowState()) return;
        if (event.pointerType !== 'mouse') return;
        if ((event.target as HTMLElement).closest('video, button, a')) return;
        event.preventDefault();
        dragging = true;
        if (frame) cancelAnimationFrame(frame);
        frame = 0;
        target = currentPosition();
        startX = lastX = event.clientX;
        startScroll = currentPosition();
        lastTime = performance.now();
        velocity = 0;
        viewport.classList.add('is-dragging');
        viewport.setPointerCapture(event.pointerId);
        viewport.addEventListener('pointermove', handlePointerMove);
        viewport.addEventListener('pointerup', release);
        viewport.addEventListener('pointercancel', release);
      });
      viewport.addEventListener('keydown', (event) => {
        if (!updateOverflowState()) return;
        if (event.key !== 'ArrowLeft' && event.key !== 'ArrowRight') return;
        event.preventDefault();
        const direction = event.key === 'ArrowRight' ? 1 : -1;
        moveTo(currentPosition() + viewport.clientWidth * 0.72 * direction);
      });
      window.addEventListener('resize', () => {
        updateOverflowState();
        target = clamp(currentPosition());
      }, { passive: true });
      rail.querySelectorAll('img').forEach((image) => {
        image.addEventListener('load', () => {
          updateOverflowState();
        }, { once: true });
      });

      updateOverflowState();
    });
  </script>

  {isTabuEkstra && (
    <>
      <section class="tabu-spread" aria-label="Tabum Ekstra visual system">
        <header class="tabu-spread__header">
          <h2>Words change with the room.</h2>
          <p>Seasonal decks keep the game current without changing the one-phone rhythm.</p>
        </header>
        <figure class="tabu-spread__image tabu-spread__image--wide">
          <img src="/landing/self-brand/summer-words.webp" alt="Summer Words event artwork for Tabum Ekstra" loading="lazy" />
          <figcaption>Summer Words · 2026</figcaption>
        </figure>
        <figure class="tabu-spread__image tabu-spread__image--poster">
          <img src="/tabu-ekstra/ramadantabu.webp" alt="Ramadan event artwork for Tabum Ekstra" loading="lazy" />
          <figcaption>Ramadan deck · 2026</figcaption>
        </figure>
      </section>
    </>
  )}

  {isRebuiltMenuApp && presentation && (
    <section class={`tabu-spread app-showcase app-showcase--${app.slug}`} aria-label={`${app.name} gameplay system`}>
      <h2>{presentation.showcaseTitle}</h2>
      <p class="app-showcase__intro">{presentation.showcaseIntro}</p>
      {showsShowcaseCards && (
        <>
          <div class="app-showcase__cards">
            {presentation.cards.map((card) => (
              <article class="app-showcase__card">
                <h3>{card.title}</h3>
                <p>{card.text}</p>
              </article>
            ))}
          </div>
        </>
      )}
    </section>
  )}

  {showsStandardAppSections && (
    <>
      <section class="app-section app-section--about">
        <h2>About</h2>
        <div class="app-section__body">{app.about.map((p) => <p>{p}</p>)}</div>
      </section>

      <section class="app-section app-section--features">
        <h2>Features</h2>
        <div class="app-section__body">
          <ul class="list">
            {app.features.map((f) => <li>{f}</li>)}
          </ul>
        </div>
      </section>

      <section class="app-section app-section--build">
        <h2>How it was built?</h2>
        <div class="app-section__body">
          {app.builtStory.map((p) => <p>{p}</p>)}

          <div class="chips">
            {app.techChips.map((c) => <span class="chip">{c}</span>)}
          </div>

          <details class="tech-details">
            <summary>Full tech stack</summary>
            <dl class="stack">
              {app.stack.map((s) => (
                <>
                  <dt>{s.label}</dt>
                  <dd>{s.value}</dd>
                </>
              ))}
            </dl>
          </details>
        </div>
      </section>

      {app.highlights && app.highlights.length > 0 && (
        <section class="app-section app-section--highlights">
          <h2>Highlights</h2>
          <div class="app-section__body">
            <ul class="list">
              {app.highlights.map((h) => <li>{h}</li>)}
            </ul>
          </div>
        </section>
      )}

      <section class="app-section app-section--technical">
        <h2>Technical details</h2>
        <div class="app-section__body">
          <div class="meta-grid">
            <div><span class="muted">Version</span><br />{app.meta.version}</div>
            <div><span class="muted">Released</span><br />{app.meta.released}</div>
            <div><span class="muted">Updated</span><br />{app.meta.updated}</div>
            <div><span class="muted">Requires</span><br />{app.meta.minOS}</div>
            <div><span class="muted">Size</span><br />{app.meta.size}</div>
            <div><span class="muted">Genre</span><br />{app.meta.genre}</div>
            {app.meta.rating && <div><span class="muted">Rating</span><br />{app.meta.rating}</div>}
          </div>
        </div>
      </section>

      <section class="bottom-cta app-final">
        <h2>Try it</h2>
        <p>{app.tagline}</p>
        <p>
          <a href={app.appStoreUrl} class="cta">Get {app.name} on the App Store →</a>
        </p>
        <p class="muted" style="margin-top: 1rem;">
          See the <a href={`/${app.slug}/privacy`}>{app.name} privacy policy</a>.
        </p>
      </section>
    </>
  )}
  </div>

</Layout>
