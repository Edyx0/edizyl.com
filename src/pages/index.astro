---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portfolio — Ediz Yılmaz" bodyClass="home">
  <section id="top" class="opening-experience" aria-labelledby="opening-title">
    <div class="opening-stage" data-phase="0">
      <div class="opening-media opening-media--back" aria-hidden="true">
        <figure class="opening-shot opening-shot--top-1">
          <span class="opening-shot__surface"><img src="/landing/self-brand/burger-streak.webp" alt="" /></span>
        </figure>
        <figure class="opening-shot opening-shot--top-2">
          <span class="opening-shot__surface"><img src="/landing/self-brand/eat-like-an-italian.webp" alt="" /></span>
        </figure>
        <figure class="opening-shot opening-shot--top-3">
          <span class="opening-shot__surface"><img src="/landing/self-brand/holy-shift-characters-a.webp" alt="" /></span>
        </figure>
        <figure class="opening-shot opening-shot--top-4">
          <span class="opening-shot__surface"><img src="/landing/self-brand/imposter.webp" alt="" /></span>
        </figure>
      </div>

      <h1 id="opening-title" class="opening-wordmark" aria-label="edizyilmaz">
        <span aria-hidden="true">ediz</span>
        <span aria-hidden="true">yilmaz</span>
      </h1>

      <div class="opening-media opening-media--front" aria-hidden="true">
        <figure class="opening-shot opening-shot--bottom-1">
          <span class="opening-shot__surface"><img src="/landing/self-brand/kebap-streak.webp" alt="" /></span>
        </figure>
        <figure class="opening-shot opening-shot--bottom-2">
          <span class="opening-shot__surface"><img src="/landing/self-brand/food-trip.webp" alt="" /></span>
        </figure>
        <figure class="opening-shot opening-shot--bottom-3">
          <span class="opening-shot__surface"><img src="/landing/self-brand/summer-words.webp" alt="" /></span>
        </figure>
        <figure class="opening-shot opening-shot--bottom-4">
          <span class="opening-shot__surface"><img src="/landing/self-brand/holy-shift-characters-b.webp" alt="" /></span>
        </figure>
        <figure class="opening-shot opening-shot--bottom-5">
          <span class="opening-shot__surface"><img src="/landing/self-brand/tabu-ekstra.webp" alt="" /></span>
        </figure>
      </div>

    </div>
  </section>

  <section id="about" class="studio-profile" aria-labelledby="about-title">
    <div class="studio-profile__lead">
      <p>About</p>
      <h2 id="about-title">
        One person,<br />
        full product loop.
      </h2>
    </div>

    <p class="studio-profile__statement">
      I build playful apps from product direction and code through design,
      acquisition, analytics, and iteration after release.
    </p>

    <dl class="studio-profile__facts">
      <div>
        <dt>Study</dt>
        <dd>
          <span>Computer Engineering</span>
          <span>Yeditepe University</span>
        </dd>
      </div>
      <div>
        <dt>Based</dt>
        <dd>
          <span>Istanbul</span>
          <span>Türkiye</span>
        </dd>
      </div>
    </dl>
  </section>

  <section id="contact" class="contact-stage" aria-labelledby="contact-title">
    <p class="contact-stage__label">Contact</p>
    <h2 id="contact-title">Let’s make<br />something unusual.</h2>

    <a class="contact-stage__email" href="mailto:edizyilmaz@icloud.com">
      edizyilmaz@icloud.com <span aria-hidden="true">↗</span>
    </a>

    <nav class="contact-stage__social" aria-label="Social profiles">
      <a href="https://linkedin.com/in/edizylm/">LinkedIn</a>
      <a href="https://github.com/Edyx0">GitHub</a>
    </nav>

    <a class="contact-stage__top" href="#top">Index — Back to top ↑</a>
  </section>

  <script>
    const body = document.body;
    const useMaskedLandingFrames = false;
    const opening = document.querySelector<HTMLElement>('.opening-experience');
    const reducedMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    let menuFrameReturnTimer = 0;

    const beginMenuFrameTransition = () => {
      if (!opening || body.dataset.openingPhase !== '3') return;
      window.clearTimeout(menuFrameReturnTimer);
      body.classList.remove('opening-menu-return');
      body.classList.add('opening-menu-transition');
    };

    const restoreMenuFrames = () => {
      if (!body.classList.contains('opening-menu-transition')) return;
      window.clearTimeout(menuFrameReturnTimer);
      body.classList.add('opening-menu-return');
      requestAnimationFrame(() => {
        requestAnimationFrame(() => body.classList.remove('opening-menu-transition'));
      });
      menuFrameReturnTimer = window.setTimeout(() => {
        body.classList.remove('opening-menu-return');
      }, 920);
    };

    window.addEventListener('site-menu:opening', beginMenuFrameTransition);
    window.addEventListener('site-menu:closed', restoreMenuFrames);

    const setMaskedLandingFrames = (enabled: boolean) => {
      body.classList.toggle('landing-masked-frames', enabled);
    };

    setMaskedLandingFrames(useMaskedLandingFrames);
    Object.assign(window, {
      toggleLandingMasks: (enabled = !body.classList.contains('landing-masked-frames')) => {
        setMaskedLandingFrames(enabled);
        return enabled;
      },
    });

    if ('scrollRestoration' in history) {
      history.scrollRestoration = 'manual';
    }
    window.scrollTo(0, 0);

    const updateHeader = () => {
      body.classList.toggle(
        'home-scrolled',
        opening ? opening.getBoundingClientRect().bottom <= 0 : true,
      );
    };

    let wasContentActive = false;
    let frameReturnTimer = 0;

    const replayOpeningFrames = () => {
      window.clearTimeout(frameReturnTimer);
      body.classList.add('opening-frame-return');
      body.classList.remove('opening-frame-return-active');
      frameReturnTimer = window.setTimeout(() => {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => body.classList.add('opening-frame-return-active'));
        });
        frameReturnTimer = window.setTimeout(() => {
          body.classList.remove('opening-frame-return', 'opening-frame-return-active');
        }, 900);
      }, 520);
    };

    const updateOpeningColor = () => {
      if (!opening) return;
      const progress = Math.min(
        Math.max(-opening.getBoundingClientRect().top / window.innerHeight, 0),
        1,
      );
      const isContentActive = progress > 0.01;
      if (wasContentActive && !isContentActive) replayOpeningFrames();
      if (!wasContentActive && isContentActive) {
        window.clearTimeout(frameReturnTimer);
        body.classList.remove('opening-frame-return', 'opening-frame-return-active');
      }
      wasContentActive = isContentActive;
      body.classList.toggle('home-content-active', isContentActive);
      body.classList.toggle('home-content-color', progress > 0.1);
    };

    const openingStage = opening?.querySelector<HTMLElement>('.opening-stage');
    const splashPalettes = [
      { name: 'rose', bg: '#f9f7f7', ink: '#e676b6' },
      { name: 'red', bg: '#f7f7f7', ink: '#e63e3e' },
      { name: 'orange', bg: '#ffffff', ink: '#e78e29' },
      { name: 'sky', bg: '#fbdada', ink: '#ace8fc' },
    ];

    const contentPalettes = [
      { name: 'blush-brown', primary: '#f1b5c2', primaryInk: '#392e2b', secondary: '#392e2b', secondaryInk: '#f9f7f7' },
      { name: 'olive-red', primary: '#6e7b48', primaryInk: '#ffffff', secondary: '#e02a47', secondaryInk: '#ffffff' },
      { name: 'forest-peach', primary: '#152d22', primaryInk: '#f9f7f7', secondary: '#f3af87', secondaryInk: '#152d22' },
      { name: 'clay-violet', primary: '#907e74', primaryInk: '#191817', secondary: '#3e2ab4', secondaryInk: '#f9f7f7' },
      { name: 'earth-coral', primary: '#3c3829', primaryInk: '#f9f7f7', secondary: '#f07082', secondaryInk: '#191817' },
      { name: 'orange-mint', primary: '#d15022', primaryInk: '#ffffff', secondary: '#75dfb5', secondaryInk: '#152d22' },
      { name: 'pink-indigo', primary: '#fe2bf7', primaryInk: '#191817', secondary: '#1c008c', secondaryInk: '#f9f7f7' },
      { name: 'lime-slate', primary: '#dbf863', primaryInk: '#191817', secondary: '#556f6e', secondaryInk: '#f9f7f7' },
    ];

    const openingThemes = splashPalettes.flatMap((splash) =>
      contentPalettes.map((content) => ({
        name: `${splash.name}-${content.name}`,
        bg: splash.bg,
        ink: splash.ink,
        accent: content.primary,
        accentInk: content.primaryInk,
        content: content.secondary,
        contentInk: content.secondaryInk,
        soft: '#ffffff',
      })),
    );

    const chooseOpeningTheme = () => {
      const previous = sessionStorage.getItem('opening-theme-key');
      const choices = openingThemes.filter((theme) => theme.name !== previous);
      const theme = choices[Math.floor(Math.random() * choices.length)] ?? openingThemes[0];
      sessionStorage.setItem('opening-theme-key', theme.name);
      return theme;
    };

    const getStoredOpeningTheme = () => {
      try {
        const storedTheme = sessionStorage.getItem('opening-theme-values');
        return storedTheme ? JSON.parse(storedTheme) : null;
      } catch (_) {
        return null;
      }
    };

    const startOpeningSequence = () => {
      if (!opening || !openingStage) return;
      const hasCompletedOpening = sessionStorage.getItem('opening-complete') === 'true';
      const theme = hasCompletedOpening ? getStoredOpeningTheme() ?? chooseOpeningTheme() : chooseOpeningTheme();
      opening.style.setProperty('--opening-bg', theme.bg);
      opening.style.setProperty('--opening-ink', theme.ink);
      opening.style.setProperty('--opening-accent', theme.accent);
      opening.style.setProperty('--opening-accent-ink', theme.accentInk);
      opening.style.setProperty('--opening-content', theme.content);
      opening.style.setProperty('--opening-content-ink', theme.contentInk);
      opening.style.setProperty('--opening-soft', theme.soft);
      body.style.setProperty('--opening-bg', theme.bg);
      body.style.setProperty('--opening-ink', theme.ink);
      body.style.setProperty('--opening-accent', theme.accent);
      body.style.setProperty('--opening-accent-ink', theme.accentInk);
      body.style.setProperty('--opening-content', theme.content);
      body.style.setProperty('--opening-content-ink', theme.contentInk);
      body.style.setProperty('--opening-soft', theme.soft);
      document.documentElement.style.setProperty('--opening-bg', theme.bg);
      document.documentElement.style.setProperty('--opening-ink', theme.ink);
      document.documentElement.style.setProperty('--opening-accent', theme.accent);
      document.documentElement.style.setProperty('--opening-accent-ink', theme.accentInk);
      document.documentElement.style.setProperty('--opening-content', theme.content);
      document.documentElement.style.setProperty('--opening-content-ink', theme.contentInk);
      document.documentElement.style.setProperty('--opening-soft', theme.soft);
      document.documentElement.dataset.openingTheme = theme.name;
      sessionStorage.setItem('opening-theme-values', JSON.stringify(theme));
      opening.dataset.theme = theme.name;
      const blockedScrollKeys = new Set([
        'ArrowDown',
        'ArrowUp',
        'End',
        'Home',
        'PageDown',
        'PageUp',
        ' ',
      ]);
      const preventOpeningScroll = (event: Event) => event.preventDefault();
      const preventOpeningKey = (event: KeyboardEvent) => {
        if (blockedScrollKeys.has(event.key)) event.preventDefault();
      };

      document.documentElement.classList.add('opening-locked');
      body.classList.add('opening-locked');
      body.classList.remove('opening-complete');
      window.addEventListener('wheel', preventOpeningScroll, { passive: false });
      window.addEventListener('touchmove', preventOpeningScroll, { passive: false });
      window.addEventListener('keydown', preventOpeningKey);

      const setPhase = (phase: number) => {
        openingStage.dataset.phase = String(phase);
        body.dataset.openingPhase = String(phase);
      };

      const unlockOpening = () => {
        document.documentElement.classList.remove('opening-locked');
        body.classList.remove('opening-locked');
        body.classList.add('opening-complete');
        window.removeEventListener('wheel', preventOpeningScroll);
        window.removeEventListener('touchmove', preventOpeningScroll);
        window.removeEventListener('keydown', preventOpeningKey);
      };

      if (hasCompletedOpening || reducedMotionQuery.matches) {
        setPhase(3);
        opening.classList.add('opening-ready');
        unlockOpening();
        return;
      }

      setPhase(0);
      opening.classList.add('opening-ready');
      [
        window.setTimeout(() => setPhase(1), 400),
        window.setTimeout(() => setPhase(2), 1200),
        window.setTimeout(() => setPhase(3), 1700),
        window.setTimeout(() => {
          sessionStorage.setItem('opening-complete', 'true');
          unlockOpening();
        }, 2000),
      ];
    };

    const startOpening = () => {
      body.classList.remove('font-loading');
      startOpeningSequence();
    };

    const onScroll = () => {
      if (body.classList.contains('opening-locked')) {
        window.scrollTo(0, 0);
        return;
      }
      updateHeader();
      updateOpeningColor();
    };

    const setupOpeningFlowHover = () => {
      if (!openingStage || reducedMotionQuery.matches) return;

      const shots = Array.from(openingStage.querySelectorAll<HTMLElement>('.opening-shot'));
      const hoveredShots = new Set<HTMLElement>();
      let currentRate = 1;
      let targetRate = 1;
      let speedFrame = 0;

      const getPhotoFlowAnimations = () =>
        openingStage.getAnimations({ subtree: true }).filter((animation) => {
          const effect = animation.effect;
          if (!(effect instanceof KeyframeEffect)) return false;
          const target = effect.target;
          return target instanceof HTMLElement && target.classList.contains('opening-shot');
        });

      const setPlaybackRate = (rate: number) => {
        targetRate = rate;
        if (speedFrame) return;

        const tick = () => {
          currentRate += (targetRate - currentRate) * 0.18;
          if (Math.abs(targetRate - currentRate) < 0.01) currentRate = targetRate;
          getPhotoFlowAnimations().forEach((animation) => {
            animation.playbackRate = currentRate;
          });
          speedFrame = currentRate === targetRate ? 0 : requestAnimationFrame(tick);
        };

        speedFrame = requestAnimationFrame(tick);
      };

      shots.forEach((shot) => {
        shot.addEventListener('pointerenter', () => {
          hoveredShots.add(shot);
          setPlaybackRate(0.35);
        });
        shot.addEventListener('pointerleave', () => {
          hoveredShots.delete(shot);
          if (!hoveredShots.size) setPlaybackRate(1);
        });
      });
    };

    updateHeader();
    updateOpeningColor();
    setupOpeningFlowHover();
    startOpening();
    window.addEventListener('scroll', onScroll, { passive: true });
  </script>
</Layout>
